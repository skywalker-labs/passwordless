{
    "name": "skywalker-labs/passwordless",
    "description": "Seamless Passwordless Authentication for Laravel. Integrate OTP (One-Time Password) Login and 2FA into your default authentication flow with zero-conf middleware and ready-to-use UI.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "otp",
        "authentication",
        "login",
        "2fa",
        "security",
        "skywalker",
        "passwordless"
    ],
    "homepage": "https://github.com/skywalker-labs/passwordless",
    "support": {
        "issues": "https://github.com/skywalker-labs/passwordless/issues",
        "source": "https://github.com/skywalker-labs/passwordless"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ermradulsharma"
        }
    ],
    "authors": [
        {
            "name": "Skywalker Labs Team",
            "email": "skywalkerlknw@gmail.com",
            "homepage": "https://skywalker-labs.com/",
            "role": "Developer"
        },
        {
            "name": "Mradul Sharma",
            "email": "skywalkerlknw@gmail.com",
            "homepage": "https://mradulsharma.vercel.app/",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "skywalker-labs/toolkit": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0",
        "larastan/larastan": "^3.9",
        "phpstan/phpstan-phpunit": "^2.0",
        "infection/infection": "^0.32"
    },
    "autoload": {
        "psr-4": {
            "Skywalker\\Otp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Skywalker\\Otp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Skywalker\\Otp\\OtpServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}